{
  "manifest_version": 3,
  "name": "Console Helper Extension",
  "version": "1.0",
  "description": "Executes a custom script when a configurable key is pressed.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Configure Shortcut"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "world": "MAIN",
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["config.js"],
      "run_at": "document_start"
    }
  ]
}
